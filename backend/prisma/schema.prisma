generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserStatus {
  active
  suspended
}

enum ListingStatus {
  pending
  active
  inactive
  blocked
}

enum GenderPreference {
  male
  female
  mixed
}

enum RoomType {
  single
  ensuite
  shared
}

enum BookingStatus {
  pending
  confirmed
  cancelled
  declined
}

enum ReportStatus {
  pending
  resolved
}

enum NotificationType {
  listing_review
  booking_update
  system
}

// ─── User Tables ──────────────────────────────────────────────────────────────

model Student {
  studentId    Int        @id @default(autoincrement()) @map("student_id")
  fullName     String     @map("full_name") @db.VarChar(100)
  email        String     @unique @db.VarChar(100)
  passwordHash String     @map("password_hash") @db.VarChar(255)
  phoneNumber  String     @unique @map("phone_number") @db.VarChar(15)
  status       UserStatus @default(active)
  createdAt    DateTime   @default(now()) @map("created_at")

  favourites    Favourite[]
  bookings      Booking[]
  reports       Report[]
  warnings      Warning[]
  notifications Notification[]

  @@map("students")
}

model Landlord {
  landlordId   Int        @id @default(autoincrement()) @map("landlord_id")
  fullName     String     @map("full_name") @db.VarChar(100)
  email        String     @unique @db.VarChar(100)
  passwordHash String     @map("password_hash") @db.VarChar(255)
  phoneNumber  String     @unique @map("phone_number") @db.VarChar(15)
  status       UserStatus @default(active)
  createdAt    DateTime   @default(now()) @map("created_at")

  listings      Listing[]
  warnings      Warning[]
  notifications Notification[]

  @@map("landlords")
}

model Agent {
  agentId      Int        @id @default(autoincrement()) @map("agent_id")
  fullName     String     @map("full_name") @db.VarChar(100)
  email        String     @unique @db.VarChar(100)
  passwordHash String     @map("password_hash") @db.VarChar(255)
  phoneNumber  String     @unique @map("phone_number") @db.VarChar(15)
  status       UserStatus @default(active)
  createdAt    DateTime   @default(now()) @map("created_at")

  listings      Listing[]
  warnings      Warning[]
  notifications Notification[]

  @@map("agents")
}

model Admin {
  adminId      Int        @id @default(autoincrement()) @map("admin_id")
  fullName     String     @map("full_name") @db.VarChar(100)
  email        String     @unique @db.VarChar(100)
  passwordHash String     @map("password_hash") @db.VarChar(255)
  phoneNumber  String     @unique @map("phone_number") @db.VarChar(15)
  status       UserStatus @default(active)
  createdAt    DateTime   @default(now()) @map("created_at")

  approvedListings  Listing[]      @relation("ApprovedBy")
  resolvedReports   Report[]
  warnings          Warning[]
  notifications     Notification[]

  @@map("admins")
}

// ─── Listings ─────────────────────────────────────────────────────────────────

model Listing {
  listingId        Int               @id @default(autoincrement()) @map("listing_id")
  landlordId       Int?              @map("landlord_id")
  agentId          Int?              @map("agent_id")
  title            String            @db.VarChar(150)
  description      String?           @db.Text
  propertyType     String?           @map("property_type") @db.VarChar(50)
  price            Decimal           @db.Decimal(10, 2)
  genderPreference GenderPreference? @map("gender_preference")
  roomType         RoomType?         @map("room_type")
  amenities        String[]
  county           String            @db.VarChar(100)
  area             String            @db.VarChar(100)
  nearestCampus    String?           @map("nearest_campus") @db.VarChar(150)
  address          String?           @db.VarChar(255)
  status           ListingStatus     @default(pending)
  approvedBy       Int?              @map("approved_by")
  approvedAt       DateTime?         @map("approved_at")
  declineReason    String?           @map("decline_reason") @db.Text
  createdAt        DateTime          @default(now()) @map("created_at")

  landlord        Landlord?      @relation(fields: [landlordId], references: [landlordId], onDelete: Cascade)
  agent           Agent?         @relation(fields: [agentId], references: [agentId], onDelete: Cascade)
  approvedByAdmin Admin?         @relation("ApprovedBy", fields: [approvedBy], references: [adminId], onDelete: SetNull)

  images      ListingImage[]
  favourites  Favourite[]
  bookings    Booking[]
  reports     Report[]
  analytics   Analytics[]

  @@map("listings")
}

model ListingImage {
  imageId   Int      @id @default(autoincrement()) @map("image_id")
  listingId Int      @map("listing_id")
  imageUrl  String   @map("image_url") @db.VarChar(500)
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at")

  listing Listing @relation(fields: [listingId], references: [listingId], onDelete: Cascade)

  @@map("listing_images")
}

// ─── Student Actions ──────────────────────────────────────────────────────────

model Favourite {
  favouriteId Int      @id @default(autoincrement()) @map("favourite_id")
  studentId   Int      @map("student_id")
  listingId   Int      @map("listing_id")
  createdAt   DateTime @default(now()) @map("created_at")

  student Student @relation(fields: [studentId], references: [studentId], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [listingId], onDelete: Cascade)

  @@unique([studentId, listingId])
  @@map("favourites")
}

model Booking {
  bookingId        Int           @id @default(autoincrement()) @map("booking_id")
  studentId        Int           @map("student_id")
  listingId        Int           @map("listing_id")
  status           BookingStatus @default(pending)
  requestNote      String?       @map("request_note") @db.Text
  providerResponse String?       @map("provider_response") @db.Text
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @default(now()) @updatedAt @map("updated_at")

  student       Student        @relation(fields: [studentId], references: [studentId], onDelete: Cascade)
  listing       Listing        @relation(fields: [listingId], references: [listingId], onDelete: Cascade)
  notifications Notification[]

  @@unique([studentId, listingId])
  @@map("bookings")
}

model Report {
  reportId       Int          @id @default(autoincrement()) @map("report_id")
  studentId      Int          @map("student_id")
  listingId      Int          @map("listing_id")
  reason         String       @db.Text
  status         ReportStatus @default(pending)
  resolutionNote String?      @map("resolution_note") @db.Text
  resolvedAt     DateTime?    @map("resolved_at")
  resolvedBy     Int?         @map("resolved_by")
  createdAt      DateTime     @default(now()) @map("created_at")

  student Student @relation(fields: [studentId], references: [studentId], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [listingId], onDelete: Cascade)
  admin   Admin?  @relation(fields: [resolvedBy], references: [adminId], onDelete: SetNull)

  @@map("reports")
}

// ─── Admin Actions ────────────────────────────────────────────────────────────

model Warning {
  warningId  Int      @id @default(autoincrement()) @map("warning_id")
  issuedBy   Int?     @map("issued_by")
  studentId  Int?     @map("student_id")
  landlordId Int?     @map("landlord_id")
  agentId    Int?     @map("agent_id")
  reason     String   @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  admin    Admin?    @relation(fields: [issuedBy], references: [adminId], onDelete: SetNull)
  student  Student?  @relation(fields: [studentId], references: [studentId], onDelete: Cascade)
  landlord Landlord? @relation(fields: [landlordId], references: [landlordId], onDelete: Cascade)
  agent    Agent?    @relation(fields: [agentId], references: [agentId], onDelete: Cascade)

  @@map("warnings")
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  notificationId Int              @id @default(autoincrement()) @map("notification_id")
  studentId      Int?             @map("student_id")
  landlordId     Int?             @map("landlord_id")
  agentId        Int?             @map("agent_id")
  adminId        Int?             @map("admin_id")
  bookingId      Int?             @map("booking_id")
  message        String           @db.Text
  type           NotificationType @default(system)
  isRead         Boolean          @default(false) @map("is_read")
  createdAt      DateTime         @default(now()) @map("created_at")

  student  Student?  @relation(fields: [studentId], references: [studentId], onDelete: Cascade)
  landlord Landlord? @relation(fields: [landlordId], references: [landlordId], onDelete: Cascade)
  agent    Agent?    @relation(fields: [agentId], references: [agentId], onDelete: Cascade)
  admin    Admin?    @relation(fields: [adminId], references: [adminId], onDelete: Cascade)
  booking  Booking?  @relation(fields: [bookingId], references: [bookingId], onDelete: SetNull)

  @@map("notifications")
}

// ─── Analytics & Logs ─────────────────────────────────────────────────────────

model Analytics {
  analyticsId Int      @id @default(autoincrement()) @map("analytics_id")
  listingId   Int      @map("listing_id")
  weekStart   DateTime @map("week_start") @db.Date
  viewCount   Int      @default(0) @map("view_count")

  listing Listing @relation(fields: [listingId], references: [listingId], onDelete: Cascade)

  @@unique([listingId, weekStart])
  @@map("analytics")
}

model ErrorLog {
  logId      Int      @id @default(autoincrement()) @map("log_id")
  message    String   @db.Text
  stackTrace String?  @map("stack_trace") @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("error_logs")
}

model TrafficLog {
  trafficId  Int      @id @default(autoincrement()) @map("traffic_id")
  date       DateTime @unique @db.Date
  visitCount Int      @default(0) @map("visit_count")

  @@map("traffic_logs")
}
