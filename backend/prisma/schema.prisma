generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserStatus {
  active
  suspended
}

enum PropertyStatus {
  draft
  pending_approval
  active
  fully_occupied
  suspended
  rejected
  archived
}

enum PropertyType {
  hostel_room
  shared_room
  studio
  bedsitter
  sq
  one_bedroom
  two_bedroom
  three_bedroom
  suite
  apartment
  maisonette
  other
}

enum GenderPreference {
  male
  female
  mixed
}

enum RoomType {
  single
  ensuite
  shared
}

enum BookingStatus {
  pending
  accepted
  rejected
  cancelled
  visited
  completed
}

enum ReportStatus {
  pending
  resolved
  dismissed
}

enum ReportReason {
  spam
  fraud
  wrong_information
  already_occupied
  inappropriate
  other
}

enum NotificationType {
  property_review
  booking_update
  visit_invitation
  warning
  suspension
  announcement
  report
  system
}

enum OtpPurpose {
  verify
  login
  reset
}

// ─── User Tables ──────────────────────────────────────────────────────────────

model Student {
  studentId    Int        @id @default(autoincrement()) @map("student_id")
  fullName     String     @map("full_name") @db.VarChar(100)
  email        String     @unique @db.VarChar(100)
  passwordHash String     @map("password_hash") @db.VarChar(255)
  phoneNumber  String     @unique @map("phone_number") @db.VarChar(15)
  status       UserStatus @default(active)
  isVerified   Boolean    @default(false) @map("is_verified")
  createdAt    DateTime   @default(now()) @map("created_at")

  favourites    Favourite[]
  bookings      Booking[]
  reports       Report[]
  warnings      Warning[]
  notifications Notification[]
  viewHistory   ViewHistory[]

  @@map("students")
}

model Landlord {
  landlordId   Int        @id @default(autoincrement()) @map("landlord_id")
  fullName     String     @map("full_name") @db.VarChar(100)
  email        String     @unique @db.VarChar(100)
  passwordHash String     @map("password_hash") @db.VarChar(255)
  phoneNumber  String     @unique @map("phone_number") @db.VarChar(15)
  status       UserStatus @default(active)
  isVerified   Boolean    @default(false) @map("is_verified")
  createdAt    DateTime   @default(now()) @map("created_at")

  properties    Property[]
  warnings      Warning[]
  notifications Notification[]

  @@map("landlords")
}

model Agent {
  agentId      Int        @id @default(autoincrement()) @map("agent_id")
  fullName     String     @map("full_name") @db.VarChar(100)
  email        String     @unique @db.VarChar(100)
  passwordHash String     @map("password_hash") @db.VarChar(255)
  phoneNumber  String     @unique @map("phone_number") @db.VarChar(15)
  status       UserStatus @default(active)
  isVerified   Boolean    @default(false) @map("is_verified")
  createdAt    DateTime   @default(now()) @map("created_at")

  properties    Property[]
  warnings      Warning[]
  notifications Notification[]

  @@map("agents")
}

model Admin {
  adminId      Int        @id @default(autoincrement()) @map("admin_id")
  fullName     String     @map("full_name") @db.VarChar(100)
  email        String     @unique @db.VarChar(100)
  passwordHash String     @map("password_hash") @db.VarChar(255)
  phoneNumber  String     @unique @map("phone_number") @db.VarChar(15)
  status       UserStatus @default(active)
  createdAt    DateTime   @default(now()) @map("created_at")

  approvedProperties Property[]     @relation("ApprovedBy")
  resolvedReports    Report[]
  warnings           Warning[]
  notifications      Notification[]

  @@map("admins")
}

// Properties

model Property {
  propertyId       Int               @id @default(autoincrement()) @map("property_id")
  landlordId       Int?              @map("landlord_id")
  agentId          Int?              @map("agent_id")
  title            String            @db.VarChar(150)
  description      String?           @db.Text
  propertyType     PropertyType      @default(other) @map("property_type")
  price            Decimal           @db.Decimal(10, 2)
  deposit          Decimal?          @db.Decimal(10, 2)
  genderPreference GenderPreference? @map("gender_preference")
  roomType         RoomType?         @map("room_type")
  amenities        String[]
  rules            String[]
  capacity         Int               @default(1)
  occupied         Int               @default(0)
  county           String            @db.VarChar(100)
  area             String            @db.VarChar(100)
  estate           String?           @db.VarChar(100)
  nearestCampus    String?           @map("nearest_campus") @db.VarChar(150)
  address          String?           @db.VarChar(255)
  latitude         Float?
  longitude        Float?
  mapLink          String?           @map("map_link") @db.VarChar(500)
  status           PropertyStatus    @default(draft)
  approvedBy       Int?              @map("approved_by")
  approvedAt       DateTime?         @map("approved_at")
  rejectionReason  String?           @map("rejection_reason") @db.Text
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @default(now()) @updatedAt @map("updated_at")

  landlord        Landlord? @relation(fields: [landlordId], references: [landlordId], onDelete: Cascade)
  agent           Agent?    @relation(fields: [agentId], references: [agentId], onDelete: Cascade)
  approvedByAdmin Admin?    @relation("ApprovedBy", fields: [approvedBy], references: [adminId], onDelete: SetNull)

  images      PropertyImage[]
  favourites  Favourite[]
  bookings    Booking[]
  reports     Report[]
  analytics   Analytics[]
  viewHistory ViewHistory[]

  @@map("properties")
}

model PropertyImage {
  imageId    Int      @id @default(autoincrement()) @map("image_id")
  propertyId Int      @map("property_id")
  imageUrl   String   @map("image_url") @db.VarChar(500)
  isPrimary  Boolean  @default(false) @map("is_primary")
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")

  property Property @relation(fields: [propertyId], references: [propertyId], onDelete: Cascade)

  @@map("property_images")
}

// ─── Student Actions ──────────────────────────────────────────────────────────

model Favourite {
  favouriteId Int      @id @default(autoincrement()) @map("favourite_id")
  studentId   Int      @map("student_id")
  propertyId  Int      @map("property_id")
  createdAt   DateTime @default(now()) @map("created_at")

  student  Student  @relation(fields: [studentId], references: [studentId], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [propertyId], onDelete: Cascade)

  @@unique([studentId, propertyId])
  @@map("favourites")
}

model Booking {
  bookingId        Int           @id @default(autoincrement()) @map("booking_id")
  studentId        Int           @map("student_id")
  propertyId       Int           @map("property_id")
  status           BookingStatus @default(pending)
  requestNote      String?       @map("request_note") @db.Text
  providerResponse String?       @map("provider_response") @db.Text
  visitDate        DateTime?     @map("visit_date")
  visitTime        String?       @map("visit_time") @db.VarChar(20)
  meetingPoint     String?       @map("meeting_point") @db.VarChar(255)
  visitNotes       String?       @map("visit_notes") @db.Text
  mapLink          String?       @map("map_link") @db.VarChar(500)
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @default(now()) @updatedAt @map("updated_at")

  student       Student        @relation(fields: [studentId], references: [studentId], onDelete: Cascade)
  property      Property       @relation(fields: [propertyId], references: [propertyId], onDelete: Cascade)
  notifications Notification[]

  @@map("bookings")
}

model Report {
  reportId       Int          @id @default(autoincrement()) @map("report_id")
  studentId      Int          @map("student_id")
  propertyId     Int          @map("property_id")
  reason         ReportReason
  details        String?      @db.Text
  status         ReportStatus @default(pending)
  resolutionNote String?      @map("resolution_note") @db.Text
  resolvedAt     DateTime?    @map("resolved_at")
  resolvedBy     Int?         @map("resolved_by")
  createdAt      DateTime     @default(now()) @map("created_at")

  student  Student  @relation(fields: [studentId], references: [studentId], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [propertyId], onDelete: Cascade)
  admin    Admin?   @relation(fields: [resolvedBy], references: [adminId], onDelete: SetNull)

  @@map("reports")
}

// ─── Admin Actions ────────────────────────────────────────────────────────────

model Warning {
  warningId  Int      @id @default(autoincrement()) @map("warning_id")
  issuedBy   Int?     @map("issued_by")
  studentId  Int?     @map("student_id")
  landlordId Int?     @map("landlord_id")
  agentId    Int?     @map("agent_id")
  reason     String   @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  admin    Admin?    @relation(fields: [issuedBy], references: [adminId], onDelete: SetNull)
  student  Student?  @relation(fields: [studentId], references: [studentId], onDelete: Cascade)
  landlord Landlord? @relation(fields: [landlordId], references: [landlordId], onDelete: Cascade)
  agent    Agent?    @relation(fields: [agentId], references: [agentId], onDelete: Cascade)

  @@map("warnings")
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  notificationId Int              @id @default(autoincrement()) @map("notification_id")
  studentId      Int?             @map("student_id")
  landlordId     Int?             @map("landlord_id")
  agentId        Int?             @map("agent_id")
  adminId        Int?             @map("admin_id")
  bookingId      Int?             @map("booking_id")
  message        String           @db.Text
  type           NotificationType @default(system)
  isRead         Boolean          @default(false) @map("is_read")
  createdAt      DateTime         @default(now()) @map("created_at")

  student  Student?  @relation(fields: [studentId], references: [studentId], onDelete: Cascade)
  landlord Landlord? @relation(fields: [landlordId], references: [landlordId], onDelete: Cascade)
  agent    Agent?    @relation(fields: [agentId], references: [agentId], onDelete: Cascade)
  admin    Admin?    @relation(fields: [adminId], references: [adminId], onDelete: Cascade)
  booking  Booking?  @relation(fields: [bookingId], references: [bookingId], onDelete: SetNull)

  @@map("notifications")
}

// ─── Analytics & Logs ─────────────────────────────────────────────────────────

model Analytics {
  analyticsId Int      @id @default(autoincrement()) @map("analytics_id")
  propertyId  Int      @map("property_id")
  weekStart   DateTime @map("week_start") @db.Date
  viewCount   Int      @default(0) @map("view_count")

  property Property @relation(fields: [propertyId], references: [propertyId], onDelete: Cascade)

  @@unique([propertyId, weekStart])
  @@map("analytics")
}

model ViewHistory {
  viewId     Int      @id @default(autoincrement()) @map("view_id")
  studentId  Int      @map("student_id")
  propertyId Int      @map("property_id")
  viewedAt   DateTime @default(now()) @updatedAt @map("viewed_at")

  student  Student  @relation(fields: [studentId], references: [studentId], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [propertyId], onDelete: Cascade)

  @@unique([studentId, propertyId])
  @@map("view_history")
}

model ErrorLog {
  logId      Int      @id @default(autoincrement()) @map("log_id")
  message    String   @db.Text
  stackTrace String?  @map("stack_trace") @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("error_logs")
}

model TrafficLog {
  trafficId  Int      @id @default(autoincrement()) @map("traffic_id")
  date       DateTime @unique @db.Date
  visitCount Int      @default(0) @map("visit_count")

  @@map("traffic_logs")
}

// ─── Auth / OTP ───────────────────────────────────────────────────────────────

model Otp {
  otpId     Int        @id @default(autoincrement()) @map("otp_id")
  email     String     @db.VarChar(100)
  role      String     @db.VarChar(20)
  codeHash  String     @map("code_hash") @db.VarChar(255)
  purpose   OtpPurpose
  expiresAt DateTime   @map("expires_at")
  consumed  Boolean    @default(false)
  createdAt DateTime   @default(now()) @map("created_at")

  @@index([email, purpose])
  @@map("otps")
}
